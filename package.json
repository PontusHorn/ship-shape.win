{
	"name": "ship-shape.win",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "npm run build && wrangler dev",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "npm run build && wrangler deploy",
		"cf-typegen": "wrangler types ./src/worker-configuration.d.ts",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"check-licenses": "license-checker --onlyAllow 'MIT;Apache-2.0;ISC;BSD-2-Clause;BSD-3-Clause;0BSD;Python-2.0;CC0-1.0;CC-BY-3.0;MPL-2.0;BlueOak-1.0.0;LGPL-3.0-or-later;Unlicense' --excludePrivatePackages --summary",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"test": "npm run test:unit && npm run test:e2e",
		"test:unit": "vitest run",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@playwright/test": "^1.49.1",
		"@storybook/addon-a11y": "^10.4.1",
		"@storybook/addon-docs": "^10.4.1",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.4.1",
		"@storybook/sveltekit": "^10.4.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^22",
		"@vitest/browser": "^4.1.7",
		"@vitest/browser-playwright": "^4.1.7",
		"@vitest/coverage-v8": "^4.1.7",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-storybook": "^10.4.1",
		"eslint-plugin-svelte": "^3.9.2",
		"globals": "^16.0.0",
		"html-validate": "^11.4.0",
		"license-checker": "^25.0.1",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.4.0",
		"storybook": "^10.4.1",
		"svelte": "^5.56.0",
		"svelte-check": "^4.4.8",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^8.0.14",
		"vitest": "^4.1.7",
		"wrangler": "^4.23.0"
	},
	"dependencies": {
		"@lucide/svelte": "^0.515.0",
		"@neodrag/svelte": "^2.3.2",
		"bits-ui": "^2.7.0"
	}
}
